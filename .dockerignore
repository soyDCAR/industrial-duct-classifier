# ── Model weights (mounted as volumes at runtime) ──────────────────────
*.pth
*.pt
*.ckpt

# ── Training data and images ───────────────────────────────────────────
img/
data/
*.jpg
*.jpeg
*.png
*.bmp

# ── Notebooks and training artifacts ──────────────────────────────────
training/
*.ipynb
.ipynb_checkpoints/
runs/
logs/
outputs/

# ── Dev and test code (not needed in any image) ────────────────────────
tests/
locustfile.py
spaces/

# ── Local environments ─────────────────────────────────────────────────
.venv/
venv/
env/
ductos_env/
.env

# ── Python bytecode ────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Config files not needed inside the container ───────────────────────
environment.yml
pyproject.toml
requirements-dev.txt
docker-compose.yml
*.md

# ── Git and IDE ────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes
.vscode/
.idea/
.github/

# ── OS artifacts ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
