img/
data/
*.jpg
*.jpeg
*.png
*.bmp
*.gif

# ── Python ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Entornos virtuales ──
.venv/
venv/
env/
ductos_env/

# ── Jupyter ──
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Artefactos de entrenamiento ──
runs/
logs/
outputs/
checkpoints/

# ── Claude Code (settings locales con rutas de máquina) ──
.claude/

# ── Variables de entorno y secrets ──
.env
.env.local
*.key

# ── IDEs ──
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Sistema operativo ──
.DS_Store
Thumbs.db
desktop.ini
